{
  "name": "lean-edits",
  "displayName": "LeanEdits",
  "publisher": "KyleThompson",
  "description": "An extension that collects fine-grained edit data from users of Lean4.",
  "version": "0.0.2",
  "icon": "figures/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/rkthomps/lean-edits"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:lean4"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "commands": [
      {
        "command": "lean-edits.showConsentUrl",
        "title": "[LeanEdits]: Show Consent Form URL"
      },
      {
        "command": "lean-edits.uploadChanges",
        "title": "[LeanEdits]: Upload Changes"
      }
    ],
    "configuration": {
      "title": "LeanEdits Configuration",
      "properties": {
        "lean-edits.participantName": {
          "title": "Participant Name",
          "type": "string",
          "description": "Name that you wrote on the consent form. Please complete the consent form if you haven't already."
        },
        "lean-edits.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "title": "Enable LeanEdits",
          "description": "Enable or disable the LeanEdits extension globally."
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "form-data": "^4.0.5"
  }
}
